# eMAG Marketplace API Configuration
# Copy this file to .env and fill in the values

# API Port (default: 8002)
API_PORT=8002

# Internal API key (must match EMAG_INTERNAL_API_KEY in the main API .env)
# Required — all /api/* routes are rejected without a valid key
INTERNAL_API_KEY=

# Platform: ro (Romania) - only RO supported for now
EMAG_PLATFORM=ro

# CORS Origins (comma-separated, optional)
CORS_ORIGINS=

# Credentials are managed dynamically via the KStock admin panel
# No hardcoded username/password needed here

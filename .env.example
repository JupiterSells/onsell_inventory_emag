# eMAG Marketplace API Configuration
# Copy this file to .env and fill in the values

# API Port (default: 8002)
API_PORT=8002

# eMAG Marketplace Credentials
# These are the username and password for the eMAG Marketplace API
# Authentication uses HTTP Basic Auth (base64 encoded username:password)
EMAG_USERNAME=your_username
EMAG_PASSWORD=your_password

# Platform: ro (Romania) - only RO supported for now
EMAG_PLATFORM=ro

# CORS Origins (comma-separated, optional)
CORS_ORIGINS=

{
  "name": "@rexven-tech/emag-api",
  "version": "1.0.0",
  "description": "eMAG Marketplace API SDK and REST API Server",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build/**/*"
  ],
  "scripts": {
    "clean": "rm -rf ./build/*",
    "build": "npm run clean && npx tsc",
    "start": "node build/index.js",
    "api": "ts-node api/server.ts",
    "api:dev": "npx nodemon --exec ts-node api/server.ts",
    "api:build": "npm run build && node build/api/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onsell/onsell_inventory_emag.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.3.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^18.14.5",
    "del-cli": "^5.0.0",
    "nodemon": "^3.0.2",
    "typescript": "^4.9.5"
  }
}
